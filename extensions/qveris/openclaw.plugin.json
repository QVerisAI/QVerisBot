{
  "id": "qveris",
  "providerAuthEnvVars": {
    "qveris": ["QVERIS_API_KEY"]
  },
  "contracts": {
    "webSearchProviders": ["qveris"]
  },
  "uiHints": {
    "webSearch.apiKey": {
      "label": "QVeris API Key",
      "help": "QVeris API key (fallback: QVERIS_API_KEY env var or tools.qveris.apiKey).",
      "sensitive": true,
      "placeholder": "qv-..."
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "webSearch": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "apiKey": {
            "type": ["string", "object"]
          },
          "toolId": {
            "type": "string"
          },
          "baseUrl": {
            "type": "string"
          }
        }
      },
      "apiKey": {
        "type": ["string", "object"]
      },
      "enabled": {
        "type": "boolean"
      },
      "region": {
        "type": "string",
        "enum": ["global", "cn"]
      },
      "baseUrl": {
        "type": "string"
      },
      "timeoutSeconds": {
        "type": "integer"
      },
      "searchTimeoutSeconds": {
        "type": "integer"
      },
      "executeTimeoutSeconds": {
        "type": "integer"
      },
      "maxResponseSize": {
        "type": "integer"
      },
      "searchLimit": {
        "type": "integer"
      },
      "autoMaterializeFullContent": {
        "type": "boolean"
      },
      "fullContentMaxBytes": {
        "type": "integer"
      },
      "fullContentTimeoutSeconds": {
        "type": "integer"
      }
    }
  }
}
